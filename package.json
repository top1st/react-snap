{
  "name": "@topdev/react-snap",
  "version": "2.0.1",
  "description": "Zero-configuration framework-agnostic static prerendering for SPAs",
  "main": "index.js",
  "author": "topdev <riguang102@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/top1st/react-snap.git"
  },
  "bugs": {
    "url": "https://github.com/top1st/react-snap/issues"
  },
  "homepage": "https://github.com/top1st/react-snap#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "clean-css": "4.2.1",
    "express": "4.17.1",
    "express-history-api-fallback": "2.2.1",
    "highland": "2.13.4",
    "html-minifier": "4.0.0",
    "minimalcss": "0.8.2",
    "mkdirp": "0.5.1",
    "puppeteer": "^24.0.0",
    "serve-static": "1.14.1",
    "sourcemapped-stacktrace-node": "2.1.8"
  },
  "devDependencies": {
    "dev-null-stream": "0.0.1",
    "jest": "^29.7.0",
    "markdown-toc": "1.2.0",
    "prettier": "1.18.2"
  },
  "scripts": {
    "toc": "yarn run markdown-toc -i doc/recipes.md",
    "test": "jest",
    "precommit": "prettier --write {*,src/*}.{js,json,css}"
  },
  "jest": {
    "testTimeout": 120000
  },
  "bin": {
    "react-snap": "./run.js"
  },
  "files": [
    "index.js",
    "run.js",
    "src/",
    "vendor/"
  ]
}
